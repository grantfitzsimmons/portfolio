---
import type { ImageMetadata } from 'astro'

import ProjectLayout from '@/layouts/ProjectLayout.astro'
import Section from '@/components/Section.astro'
import ProjectScreenshotGallery from '@/components/ProjectScreenshotGallery.astro'

const description =
	'A collections management platform for natural history museums and research collections. 100% open-source and free to use.'

const screenshotModules = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/projects/specify-7/screenshots/*.{png,jpg,jpeg,gif,webp}',
	{ eager: true }
)

const screenshotTitleOverrides: Record<string, string> = {
	homepage: 'Homepage',
	queryBuilder: 'Query Builder',
	geoMappedQueryResults: 'Geo-mapped Query Results',
	dataEntryForms: 'Data Entry Forms',
	taxonomicTree: 'Taxonomic Tree',
	attachmentsPage: 'Attachments Page',
	attachmentZoom: 'Attachment Viewer (Pan and Zoom)',
	backupDatabaseUtility: 'Database Backup Utility',
	systemConfigurationTool: 'System Configuration Tool',
	linkedRecordsButton: 'Linked Records Button',
	generatedSpecimenLabels: 'Generated Specimen Labels',
	collectionStatisticsPage: 'Collection Statistics Page'
}

const screenshotOrder = [
	'homepage',
	'queryBuilder',
	'geoMappedQueryResults',
	'dataEntryForms',
	'taxonomicTree',
	'attachmentsPage',
	'attachmentZoom',
	'backupDatabaseUtility',
	'systemConfigurationTool',
	'linkedRecordsButton',
	'generatedSpecimenLabels',
	'collectionStatisticsPage'
]

const screenshots = Object.entries(screenshotModules)
	.map(([path, module]) => {
		const filename = path.split('/').pop()?.replace(/\.[^/.]+$/, '') ?? ''
		const title =
			screenshotTitleOverrides[filename] ||
			filename
				.replace(/([A-Z])/g, ' $1')
				.replace(/[-_]+/g, ' ')
				.replace(/^./, (char) => char.toUpperCase())

		return {
			filename,
			title,
			image: module.default
		}
	})
	.sort((a, b) => {
		const aIndex = screenshotOrder.indexOf(a.filename)
		const bIndex = screenshotOrder.indexOf(b.filename)
		const safeA = aIndex === -1 ? Number.MAX_SAFE_INTEGER : aIndex
		const safeB = bIndex === -1 ? Number.MAX_SAFE_INTEGER : bIndex
		return safeA - safeB
	})
---

<ProjectLayout
	title='Specify 7'
	description={description}
		coverImage='/src/assets/projects/specify-7/screenshots/homepage.png'
	coverAlt='Specify 7 interface preview'
	role='Technical Support Manager; product requirements, implementation advising, and documentation lead'
	dates='Late 2021 - Present'
	externalLink='https://sp7demofish.specifycloud.org/'
	externalLabel='Open demo'
>
	<Section title='Overview'>
		<p class='text-muted-foreground'>
			Specify 7 is a modern collections management platform for natural history and
			earth science institutions. As Product and Technical Support Manager for the
			Specify Collections Consortium since May 2023, I serve as the functional product
			lead and subject matter expert. I translate complex user feedback into technical
			software requirements, define the strategic roadmap for platform development,
			and oversee all support and documentation operations for over 450 member collections
			across 22 countries in 6 continents.
		</p>
		<p class='mt-4 text-muted-foreground'>
			My work spans the full product lifecycle: strategic leadership and international
			partnerships, product requirements and implementation advising, quality assurance
			and user experience testing, direct software engineering contributions (1,700+
			commits since 2024), operational management and KPI tracking, and global community
			engagement through workshops, webinars, and conference presentations.
		</p>
	</Section>
	<Section title='Core Platform Capabilities'>
		<ul class='ml-4 list-disc text-muted-foreground'>
			<li>Advanced query builder workflows with geo-mapped query outputs.</li>
			<li>Configurable data-entry forms, taxonomy workflows, and specimen-label generation.</li>
			<li>Attachment management with an upgraded viewer experience.</li>
			<li>Built-in backup utility and administrative configuration tooling.</li>
			<li>Linked-record visibility and collection-level statistics for safer edits and analysis.</li>
		</ul>
	</Section>
	<Section title='Direct Code Contributions'>
		<ul class='ml-4 list-disc text-muted-foreground'>
			<li>Revamped the attachment viewer with pan and zoom support.</li>
			<li>
				Built the in-app database backup utility, including automatic health checks
				and compression.
			</li>
			<li>
				Delivered the System Config tool for institutional hierarchy configuration,
				including a D3 visualization for database structure.
			</li>
			<li>
				Contributed backend Django migrations to resolve data migration issues and
				improve upgrade reliability.
			</li>
			<li>Added timestamp support in queries.</li>
			<li>Defined defaults for forms, database schema, and related workflows.</li>
			<li>Added proper UI time-zone support for notifications and user actions.</li>
			<li>Assisted in UI/UX design and implementation decisions across features.</li>
			<li>
				Added a linked-records button so users can see how many records are affected
				before committing changes.
			</li>
			<li>
				Wrote requirements for all new features since 2023 and partnered closely with
				developers through implementation.
			</li>
			<li>
				Write release notes and documentation for every update, published on the
				Speciforum.
			</li>
		</ul>
		<p class='text-muted-foreground'>
			See the related community and documentation work on
			<a href='/projects/specify-community-forum/' class='font-medium text-foreground underline underline-offset-4'>
				the Specify Community Forum project page
			</a>.
		</p>
	</Section>
	<Section title='Strategic Leadership & Business Impact'>
		<p class='text-muted-foreground mb-4'>
			Beyond software engineering, I have driven significant strategic growth and operational
			improvements for the Specify Collections Consortium:
		</p>
		<ul class='ml-4 list-disc text-muted-foreground'>
			<li>
				<strong>Pricing & Operations:</strong> Co-led the restructuring of Consortium
				membership levels and pricing tiers following formal cost assessments and future
				forecasts, ensuring alignment with operational costs, cloud infrastructure expenses,
				and global market demands.
			</li>
			<li>
				<strong>Infrastructure & Cost Optimization:</strong> Architect and maintain AWS
				cloud infrastructure (EC2, RDS, S3), ensuring high availability for mission-critical
				portals across 6 continents.
			</li>
			<li>
				<strong>Operational Management:</strong> Established new internal development processes
				using staged milestones to ensure software aligns with community needs. Monitor KPIs
				and metrics to evaluate service quality and operational effectiveness.
			</li>
		</ul>
	</Section>
	<Section title='GeoSpecify: Expanding into Earth Sciences'>
		<p class='text-muted-foreground mb-4'>
			I played a part in a multi-institutional collaborative effort to design and launch
			<strong>GeoSpecify</strong>, a specialized extension of Specify 7 for managing
			geological and mineralogical collections. This represents the Consortium's strategic
			expansion beyond biological collections.
		</p>
		<ul class='ml-4 list-disc text-muted-foreground'>
			<li>
				Conducted extensive requirements gathering with geological curators and researchers
				across multiple institutions to define information models aligned with international
				geological data standards.
			</li>
			<li>
				Orchestrated the design phase with cross-functional partners including the
				Swiss Academy of Sciences, Naturhistorisches Museum Bern, and a steering committee of
				curators and researchers from Switzerland and beyond.
			</li>
			<li>
				Standardized the requirements-gathering process for new domain extensions, creating
				a replicable framework for future platform expansions.
			</li>
			<li>
				Successfully mapped geological workflows and partnered with the development team
				through implementation, launching to public release in late 2025.
			</li>
		</ul>
		<p class='mt-4 text-muted-foreground'>
			See
			<a href='/projects/geo-specify/' class='font-medium text-foreground underline underline-offset-4'>
				the GeoSpecify project page
			</a>
			for more details on this expansion effort.
		</p>
	</Section>
	<Section title='Global Community Impact'>
		<p class='text-muted-foreground mb-4'>
			I have built the Specify Collections Consortium into a thriving global community
			through intentional engagement, support infrastructure, and knowledge sharing:
		</p>
		<ul class='ml-4 list-disc text-muted-foreground'>
			<li>
				<strong>Specify Community Forum:</strong> Architected and launched the official
				Specify Community Forum in 2022, transforming it into the primary global support
				hub. Authored 600+ forum posts and created 500+ knowledge-base topics, creating
				a durable, self-service technical repository for the global community. The forum
				has become the #1 source of information for the Consortium.
			</li>
			<li>
				<strong>Support & Supervision:</strong> Recruit, train, and supervise student
				support staff who provide responsive technical assistance for over 450 member
				collections. Direct daily workflows to ensure consistent, high-quality support.
			</li>
			<li>
				<strong>Mentoring & Onboarding:</strong> Mentor 15+ undergraduate students in
				biodiversity informatics, providing guidance on software development and technical
				support methodologies. Developed hundreds of documentation articles for onboarding
				and training new team members.
			</li>
		</ul>
	</Section>
	<Section title='Teaching, Workshops & Conference Leadership'>
		<p class='text-muted-foreground mb-4'>
			I am a prominent voice in the biodiversity informatics community, delivering
			technical training and presenting research at major international conferences:
		</p>
		<div class='text-muted-foreground'>
			<p class='font-semibold text-foreground mt-4'>Selected Conference Presentations:</p>
			<ul class='ml-4 list-disc mt-2'>
				<li>
					"Advancing Biological Collections Computing with Specify 7: A Year of
					Transformational Updates" – SPNHC Annual Meeting (May 2023)
				</li>
				<li>
					"Data cleaning for maximum impact: Tools and workflows for data providers" –
					Digital Data Conference (May 2024)
				</li>
				<li>
					"GeoSpecify, a Collection Management Platform for Geological Objects" –
					European Mineralogical Conference (August 2024)
				</li>
				<li>
					"Digitization Planning for Large Collections with Specify 7" –
					SPNHC-TDWG Joint Conference, Okinawa (September 2024)
				</li>
				<li>
					"Extending Specify 7 for Geoscience Collections" – SPNHC Annual Meeting
					(September 2024)
				</li>
				<li>
					"Publishing Your Data with Specify 7" – SPNHC Annual Meeting (May 2025)
				</li>
			</ul>
			<p class='font-semibold text-foreground mt-4'>Hosted Multi-Day Workshops:</p>
			<ul class='ml-4 list-disc mt-2'>
				<li>SwissCollNet, Natural History Museums of Switzerland (June 2023)</li>
				<li>Canadian Forest Service, Victoria, British Columbia (February 2024)</li>
				<li>
					Western Australia Herbarium, Department of Biodiversity, Conservation and
					Attractions (September 2024)
				</li>
				<li>
					University of Kansas Society for the Preservation of Natural History Collections
					(May 2025)
				</li>
				<li>Florida Museum of Natural History, University of Florida (October 2025)</li>
				<li>CSIC-MNCN, Museo Nacional de Ciencias Naturales, Madrid, Spain (December 2025)</li>
			</ul>
			<p class='font-semibold text-foreground mt-4'>Panelist & Regular Facilitator:</p>
			<ul class='ml-4 list-disc mt-2'>
				<li>BioDigiCon Digitization Conference panel discussions (2023–present)</li>
				<li>iDigBio Digitization Academy speaker (2023, 2024, 2025)</li>
				<li>Bionomia Workshop panelist on linking people and specimens (2024)</li>
				<li>Regular webinar facilitator on Specify topics with global institutions</li>
				<li>GBIF and TDWG meeting representative advancing SCC strategic interests</li>
			</ul>
		</div>
	</Section>
	<Section title='Screenshots'>
		<ProjectScreenshotGallery
			screenshots={screenshots}
			galleryId='specify-7'
			showFeatureSteps={true}
		/>
	</Section>
</ProjectLayout>
