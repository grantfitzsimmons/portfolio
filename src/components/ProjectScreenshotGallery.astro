---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface ScreenshotItem {
	title: string
	image: ImageMetadata
}

interface Props {
	screenshots: ScreenshotItem[]
	galleryId: string
	showFeatureSteps?: boolean
}

const { screenshots, galleryId, showFeatureSteps = false } = Astro.props
---

<div data-lightbox-gallery={galleryId}>
	{
		showFeatureSteps && (
			<div class='mb-4'>
				<p class='mb-2 text-sm font-medium text-foreground'>Feature Steps</p>
				<div class='flex flex-wrap gap-2'>
					{
						screenshots.map((screenshot, index) => (
							<button
								type='button'
								class='rounded-lg border border-border bg-primary-foreground px-3 py-1.5 text-sm text-muted-foreground transition-all hover:border-foreground/25 hover:text-foreground'
								data-lightbox-open={index.toString()}
							>
								{screenshot.title}
							</button>
						))
					}
				</div>
			</div>
		)
	}

	<div class='grid gap-4 sm:grid-cols-2'>
		{
			screenshots.map((screenshot, index) => (
				<figure class='overflow-hidden rounded-2xl border border-border bg-primary-foreground'>
					<button
						type='button'
						class='block w-full text-left'
						data-lightbox-open={index.toString()}
					>
						<Image
							src={screenshot.image}
							alt={screenshot.title}
							class='h-52 w-full object-cover'
							loading='lazy'
							sizes='(min-width: 640px) 50vw, 100vw'
						/>
					</button>
					<figcaption class='px-4 py-3 text-sm text-muted-foreground'>
						{screenshot.title}
					</figcaption>
				</figure>
			))
		}
	</div>

	<dialog
		id={`${galleryId}-dialog`}
		class='w-[min(96vw,1100px)] rounded-2xl border border-border bg-background p-0 text-foreground backdrop:bg-background/80'
	>
		<div class='flex items-center justify-between border-b border-border px-4 py-3'>
			<h2 id={`${galleryId}-title`} class='text-sm font-medium'>Screenshot</h2>
			<button
				type='button'
				id={`${galleryId}-close`}
				class='rounded-lg border border-border bg-primary-foreground px-2 py-1 text-sm transition-all hover:border-foreground/25'
			>
				Close
			</button>
		</div>
		<div class='relative'>
			<img id={`${galleryId}-image`} alt='' class='max-h-[80vh] w-full object-contain' />
			<button
				type='button'
				id={`${galleryId}-prev`}
				class='absolute left-3 top-1/2 -translate-y-1/2 rounded-full border border-border bg-primary-foreground/95 p-2 transition-all hover:border-foreground/25'
				aria-label='Previous screenshot'
			>
				<svg viewBox='0 0 24 24' class='h-5 w-5'>
					<path fill='currentColor' d='m15.5 19l-7-7l7-7l1.4 1.4L11.3 12l5.6 5.6z'></path>
				</svg>
			</button>
			<button
				type='button'
				id={`${galleryId}-next`}
				class='absolute right-3 top-1/2 -translate-y-1/2 rounded-full border border-border bg-primary-foreground/95 p-2 transition-all hover:border-foreground/25'
				aria-label='Next screenshot'
			>
				<svg viewBox='0 0 24 24' class='h-5 w-5'>
					<path fill='currentColor' d='m8.5 19l-1.4-1.4L12.7 12L7.1 6.4L8.5 5l7 7z'></path>
				</svg>
			</button>
		</div>
	</dialog>
</div>

<script>
	const galleryRoots = document.querySelectorAll('[data-lightbox-gallery]')

	galleryRoots.forEach((root) => {
		if (!(root instanceof HTMLElement) || root.dataset.lightboxInitialized === 'true') return
		root.dataset.lightboxInitialized = 'true'

		const galleryId = root.dataset.lightboxGallery
		if (!galleryId) return

		const dialog = root.querySelector(`#${galleryId}-dialog`)
		const lightboxImage = root.querySelector(`#${galleryId}-image`)
		const lightboxTitle = root.querySelector(`#${galleryId}-title`)
		const closeBtn = root.querySelector(`#${galleryId}-close`)
		const prevBtn = root.querySelector(`#${galleryId}-prev`)
		const nextBtn = root.querySelector(`#${galleryId}-next`)
		const figures = [...root.querySelectorAll('figure')]

		if (!(dialog instanceof HTMLDialogElement)) return
		if (!(lightboxImage instanceof HTMLImageElement)) return
		if (!(lightboxTitle instanceof HTMLElement)) return

		const items = figures
			.map((figure) => {
				const image = figure.querySelector('img')
				const caption = figure.querySelector('figcaption')
				if (!(image instanceof HTMLImageElement) || !(caption instanceof HTMLElement)) return null
				return {
					src: image.getAttribute('src') || '',
					alt: image.alt,
					title: caption.textContent || ''
				}
			})
			.filter((item) => item !== null)

		let currentIndex = 0

		const renderLightbox = (index: number) => {
			if (items.length === 0) return
			const safeIndex = ((index % items.length) + items.length) % items.length
			currentIndex = safeIndex
			const current = items[safeIndex]
			lightboxImage.src = current.src
			lightboxImage.alt = current.alt
			lightboxTitle.textContent = current.title
		}

		const openLightbox = (index: number) => {
			renderLightbox(index)
			dialog.showModal()
		}

		root.querySelectorAll('[data-lightbox-open]').forEach((trigger) => {
			trigger.addEventListener('click', () => {
				if (!(trigger instanceof HTMLElement)) return
				const index = Number(trigger.dataset.lightboxOpen)
				if (Number.isNaN(index)) return
				openLightbox(index)
			})
		})

		prevBtn?.addEventListener('click', () => renderLightbox(currentIndex - 1))
		nextBtn?.addEventListener('click', () => renderLightbox(currentIndex + 1))
		closeBtn?.addEventListener('click', () => dialog.close())

		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) dialog.close()
		})

		document.addEventListener('keydown', (event) => {
			if (!dialog.open) return
			if (event.key === 'ArrowLeft') renderLightbox(currentIndex - 1)
			if (event.key === 'ArrowRight') renderLightbox(currentIndex + 1)
		})
	})
</script>
